# ===========================================
# ENZIU Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# Never commit .env to version control
# ===========================================

# ===========================================
# Inference Service (LLM API - e.g., Llama 3.3 70B)
# Provider-agnostic - works with NScale, OpenAI, etc.
# ===========================================
INFERENCE_API_KEY=your_inference_api_key_here
INFERENCE_API_BASE=https://inference.api.nscale.com/v1
INFERENCE_MODEL=meta-llama/Llama-3.3-70B-Instruct

# Cheaper model for free sneak peek (optional—falls back to INFERENCE_*)
SNEAK_PEEK_MODEL=Qwen/Qwen3-14B

# Cheaper model for deep dive chat Q&A (optional—falls back to INFERENCE_*)
CHAT_MODEL=Qwen/Qwen3-8B

# ===========================================
# Upstash Redis (Session State & Vouchers)
# ===========================================
UPSTASH_REDIS_REST_URL="https://xxxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token_here

# ===========================================
# Paddle Billing (Payment Processing)
# ===========================================
PADDLE_ENV=sandbox
PADDLE_CLIENT_TOKEN=your_paddle_client_token_here
PADDLE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
PADDLE_PRODUCT_ID=pro_xxxxxxxxxxxxxxxxx
PADDLE_API_KEY=pdl_sdbx_apikey_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===========================================
# Voucher System (HMAC Secret)
# ===========================================
# Generate a secure random string (e.g., openssl rand -hex 32)
VOUCHER_HMAC_SECRET=your_hmac_secret_here

# ===========================================
# Application Settings
# ===========================================
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# ===========================================
# CORS Settings
# ===========================================
ALLOWED_ORIGINS=https://enziu.vercel.app,http://localhost:3000

# ===========================================
# Security Settings
# ===========================================
# Generate API secret key: openssl rand -hex 32
API_SECRET_KEY=your_64_character_secret_key_here

# Rate Limiting (requests per minute)
# Adjust based on your traffic and resource constraints
RATE_LIMIT_UPLOAD=10        # Expensive AI processing
RATE_LIMIT_CHAT=30          # AI inference
RATE_LIMIT_VOUCHER=20       # Financial operations
RATE_LIMIT_HEALTH=100       # Health checks
RATE_LIMIT_GENERAL=100      # General API endpoints

# File Upload Limits
MAX_UPLOAD_SIZE_MB=10       # Maximum file size in MB

# Request Timeout
REQUEST_TIMEOUT=60          # Maximum request processing time in seconds