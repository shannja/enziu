# ===========================================
# ENZIU Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# Never commit .env to version control
# ===========================================

# ===========================================
# NScale Inference (Llama 3.3 70B Instruct)
# ===========================================
# Get your API key from https://nscale.com
NSCALE_API_KEY=nscale_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NSCALE_API_BASE=https://api.nscale.com/v1
NSCALE_MODEL=llama-3.3-70b-instruct

# ===========================================
# Upstash Redis (Session State & Vouchers)
# ===========================================
# Create a database at https://upstash.com
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=Axxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===========================================
# Paddle Billing (Payment Processing)
# ===========================================
# Get your keys from https://vendors.paddle.com
PADDLE_ENV=sandbox
PADDLE_CLIENT_TOKEN=xxxxx-live-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PADDLE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PADDLE_PRODUCT_ID=xxxxx

# ===========================================
# Voucher System (HMAC Secret)
# ===========================================
# Generate a secure random string (e.g., openssl rand -hex 32)
VOUCHER_HMAC_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===========================================
# Application Settings
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:8000/api
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# ===========================================
# CORS Settings
# ===========================================
ALLOWED_ORIGINS=https://enziu.com,https://www.enziu.com,http://localhost:3000

# ===========================================
# Security Settings
# ===========================================
# Generate API secret key: openssl rand -hex 32
API_SECRET_KEY=your_64_character_secret_key_here

# Rate Limiting (requests per minute)
# Adjust based on your traffic and resource constraints
RATE_LIMIT_UPLOAD=10        # Expensive AI processing
RATE_LIMIT_CHAT=30          # AI inference
RATE_LIMIT_VOUCHER=20       # Financial operations
RATE_LIMIT_HEALTH=100       # Health checks
RATE_LIMIT_GENERAL=100      # General API endpoints

# File Upload Limits
MAX_UPLOAD_SIZE_MB=10       # Maximum file size in MB

# Request Timeout
REQUEST_TIMEOUT=60          # Maximum request processing time in seconds
